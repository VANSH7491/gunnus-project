# MongoDB connection (defaults match docker-compose)
MONGO_URI=mongodb://mongo:27017
MONGO_DB=metadata_inventory
MONGO_COLLECTION=pages

# MongoDB connection resilience (how long to wait for Mongo on startup)
MONGO_CONNECT_RETRIES=10
MONGO_CONNECT_BACKOFF_SECONDS=1.5

# Outbound fetcher
FETCH_TIMEOUT_SECONDS=15
FETCH_MAX_BYTES=5000000
FETCH_MAX_REDIRECTS=5
FETCH_USER_AGENT=MetadataInventoryBot/1.0 (+https://example.com/bot)

# Logging
LOG_LEVEL=INFO
