# --- MongoDB ---------------------------------------------------------------
MONGO_URI=mongodb://mongo:27017
MONGO_DB=metadata_inventory
MONGO_COLLECTION=pages

# How long the API tries to reach Mongo on startup before giving up
MONGO_CONNECT_RETRIES=10
MONGO_CONNECT_BACKOFF_SECONDS=1.5

# --- Outbound fetcher ------------------------------------------------------
FETCH_TIMEOUT_SECONDS=15
FETCH_MAX_BYTES=5000000
FETCH_MAX_REDIRECTS=5
FETCH_USER_AGENT=Mozilla/5.0 (compatible; metadata-inventory/1.0)

# --- SSRF defense (rejects loopback / private IP literals) -----------------
# Set to true for local dev when you legitimately need to fetch from
# http://localhost:... or RFC1918 ranges.
ALLOW_PRIVATE_HOSTS=false

# --- Concurrency / staleness ----------------------------------------------
# Concurrent GETs for the same URL whose record is already PENDING within
# this window are NOT re-scheduled (avoids duplicate upstream fetches).
# Older pending records are treated as stuck and retried.
PENDING_GRACE_SECONDS=30

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
